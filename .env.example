# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# WHATSAPP_VERIFY_TOKEN: Token used to verify the webhook in Meta Developers panel
WHATSAPP_VERIFY_TOKEN="amot_token_secure"
# WHATSAPP_ACCESS_TOKEN: Permanent access token from Meta Developers
WHATSAPP_ACCESS_TOKEN=""
# WHATSAPP_PHONE_ID: The phone number ID provided by Meta
WHATSAPP_PHONE_ID=""
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
